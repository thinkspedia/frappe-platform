# =============================================================================
# Frappe Platform — Dokploy Production Environment
#
# USAGE:
#   Paste the contents of this file into Dokploy UI:
#   Project → ERPNext App → Environment Variables
#
#   This file configures what runs INSIDE the containers.
#   It is NOT a local shell env file — do not `source` it.
#
#   For local `make` CLI secrets (API token, registry credentials),
#   see platform/.env.stg.example and platform/.env.prod.example.
# =============================================================================

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------
IMAGE_REGISTRY=registry.corp.thinkspedia.id/frappe/nusakura
IMAGE_TAG=v1.0.1
PULL_POLICY=always

# -----------------------------------------------------------------------------
# Site
# SITE_NAME must match the bench new-site name (usually same as the domain).
# FRAPPE_SITE_NAME_HEADER is what nginx uses to pick the correct site_config.json.
# SITE_HOST_NAME is written into site_config.json for email link generation.
# -----------------------------------------------------------------------------
FRAPPE_SITE_NAME_HEADER=nusakura-stg.erp.thinkspedia.id
TRAEFIK_ROUTER_NAME=nusakura-stg
SITE_NAME=nusakura-stg.erp.thinkspedia.id
SITE_HOST_NAME=https://nusakura-stg.erp.thinkspedia.id

# Port published to the host — must match Dokploy UI → Domain → Port.
HTTP_PUBLISH_PORT=8088

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Credentials (used by create-site)
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=CHANGE_ME
INSTALL_APP_ARGS=--install-app erpnext --install-app hrms --install-app nusakura_app

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# -----------------------------------------------------------------------------
# Gunicorn workers
# Formula: GUNICORN_WORKERS = (2 × CPU cores) + 1
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# -----------------------------------------------------------------------------
# Nginx tuning
# -----------------------------------------------------------------------------
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# -----------------------------------------------------------------------------
# One-time task triggers
# Set to 1, redeploy, then reset to 0 and redeploy again.
#
# CREATE_SITE=1  → provision a new Frappe site (first deploy only)
# MIGRATE=1      → run bench migrate with maintenance mode
# REGENERATE_APPS_TXT=1 → rebuild sites/apps.txt (run after adding/removing apps)
#
# NOTE: configurator runs automatically on every deploy — no trigger needed.
# -----------------------------------------------------------------------------
CREATE_SITE=0
MIGRATE=0
REGENERATE_APPS_TXT=1
