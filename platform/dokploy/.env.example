# =============================================================================
# Frappe Platform — Dokploy Production Environment
#
# USAGE:
#   Copy this file to platform/dokploy/.env (never commit .env)
#   Set values in Dokploy UI → Project → Environment Variables
#   OR use this file for local `make deploy-dokploy` dry-runs
# =============================================================================

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------
IMAGE_REGISTRY=registry.corp.thinkspedia.id/frappe/nusakura
IMAGE_TAG=v1.0.0
PULL_POLICY=always
RESTART_POLICY=unless-stopped

# -----------------------------------------------------------------------------
# Site
# Set FRAPPE_SITE_NAME_HEADER to your production domain so nginx knows which
# site_config.json to load. Must match the site name created with bench new-site.
# -----------------------------------------------------------------------------
FRAPPE_SITE_NAME_HEADER=erp.nusakura.co.id

# Port that Dokploy's proxy routes to. Match this in Dokploy UI domain config.
HTTP_PUBLISH_PORT=8080

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=changeme_strong_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# -----------------------------------------------------------------------------
# Gunicorn workers
# Formula: GUNICORN_WORKERS = (2 × CPU cores) + 1
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# -----------------------------------------------------------------------------
# Migration — set to false to skip bench migrate on deploy
# -----------------------------------------------------------------------------
MIGRATE_SITES=true

# -----------------------------------------------------------------------------
# Nginx tuning
# -----------------------------------------------------------------------------
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m
