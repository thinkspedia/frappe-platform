# =============================================================================
# Thinkspedia Frappe Platform — Production Image
#
# Build from repo root:
#   make build tag=v1.2.3
#
# The layered strategy uses prebuilt frappe/build + frappe/base images from
# Docker Hub, so only our app layer is rebuilt on each release — fast builds.
#
# apps.json is passed as a BuildKit secret so GITHUB_TOKEN is never baked
# into an image layer.
# =============================================================================

ARG FRAPPE_BRANCH=version-16
ARG FRAPPE_IMAGE_PREFIX=frappe

# ---------------------------------------------------------------------------
# Stage 1 — builder: bench init + bench get-app (all apps installed)
# ---------------------------------------------------------------------------
FROM ${FRAPPE_IMAGE_PREFIX}/build:${FRAPPE_BRANCH} AS builder

ARG FRAPPE_BRANCH=version-16
ARG FRAPPE_PATH=https://github.com/frappe/frappe
# Increment CACHE_BUST to force a fresh app clone (e.g. make build tag=v1.0.0 bust=1)
ARG CACHE_BUST=""

USER frappe

RUN --mount=type=secret,id=apps_json,target=/opt/frappe/apps.json,uid=1000,gid=1000 \
  : "${CACHE_BUST}" && \
  export APP_INSTALL_ARGS="" && \
  if [ -f /opt/frappe/apps.json ] && [ -s /opt/frappe/apps.json ]; then \
    export APP_INSTALL_ARGS="--apps_path=/opt/frappe/apps.json"; \
  fi && \
  bench init ${APP_INSTALL_ARGS} \
    --frappe-branch=${FRAPPE_BRANCH} \
    --frappe-path=${FRAPPE_PATH} \
    --no-procfile \
    --no-backups \
    --skip-redis-config-generation \
    --verbose \
    /home/frappe/frappe-bench && \
  cd /home/frappe/frappe-bench && \
  echo "{}" > sites/common_site_config.json && \
  find apps -mindepth 1 -path "*/.git" | xargs rm -rf

# ---------------------------------------------------------------------------
# Stage 2 — runtime: copy bench from builder into the minimal base image
# ---------------------------------------------------------------------------
FROM ${FRAPPE_IMAGE_PREFIX}/base:${FRAPPE_BRANCH} AS backend

USER frappe

COPY --from=builder --chown=frappe:frappe /home/frappe/frappe-bench /home/frappe/frappe-bench

WORKDIR /home/frappe/frappe-bench

# Move compiled assets into the image layer so they survive volume mounts.
# main-entrypoint.sh re-links sites/assets → this path on every container start.
RUN cp -r /home/frappe/frappe-bench/sites/assets /home/frappe/frappe-bench/assets && \
  rm -rf /home/frappe/frappe-bench/sites/assets

VOLUME [ \
  "/home/frappe/frappe-bench/sites", \
  "/home/frappe/frappe-bench/logs" \
]

USER root

COPY platform/resources/main-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 755 /usr/local/bin/entrypoint.sh

COPY platform/resources/start.sh /usr/local/bin/start.sh
RUN chmod 755 /usr/local/bin/start.sh

USER frappe

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["start.sh"]
