# =============================================================================
# Production environment overrides — platform/.env.prod
#
# Copy to .env.prod and fill in real values. Never commit .env.prod.
#
# Usage:
#   make deploy-dokploy tag=v1.0.0 env=prod
#   make dokploy-status env=prod
#   make prod-new-site env=prod
# =============================================================================

# Dokploy project name (must match the project name in Dokploy UI)
DOKPLOY_PROJECT_NAME=nusakura-erp-prod

# Dokploy server URL and API token (Settings → Profile → API/CLI Keys)
DOKPLOY_SERVER=https://vps.thinkspedia.id/
DOKPLOY_TOKEN=

# Site name — must match FRAPPE_SITE_NAME_HEADER in Dokploy compose env
PROD_SITE_NAME=nusakura.erp.thinkspedia.id

# Database root password (set in Dokploy compose env as DB_ROOT_PASSWORD)
DB_ROOT_PASSWORD=

# ERPNext Administrator password
SITE_ADMIN_PASSWORD=
