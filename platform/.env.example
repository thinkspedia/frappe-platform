# =============================================================================
# Frappe Platform — Environment Configuration
# SOURCE OF TRUTH for all services: dev compose, Nomad, Dokploy, org-bench.
#
# USAGE:
#   cp platform/.env.example platform/.env
#   Edit platform/.env with your actual values.
#   Never commit platform/.env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Image & Version
# -----------------------------------------------------------------------------
# The Docker image tag to build and deploy.
# Set by `org-bench build --tag <value>` and read by deploy commands.
IMAGE_REGISTRY=ghcr.io/thinkspedia
IMAGE_NAME=frappe-platform
IMAGE_TAG=latest

# Frappe branch — drives bench init and all bench get-app calls in dev.
# Must also match the frappe/build:<branch> tag used in the production Dockerfile.
FRAPPE_BRANCH=version-16

# frappe/bench image tag for local development (use latest or pin to a digest)
FRAPPE_BENCH_TAG=latest

# Upstream image prefix for production builds (change only for private mirrors)
FRAPPE_IMAGE_PREFIX=frappe

# -----------------------------------------------------------------------------
# Site Configuration
# The site name controls URL routing. For local dev: dev.localhost
# For production: your actual domain (e.g., erp.example.com).
# This value is written into site_config.json as host_name by configure-site.sh
# -----------------------------------------------------------------------------
FRAPPE_SITE_NAME=dev.localhost
SITE_ADMIN_PASSWORD=changeme

# Production/staging site name — used by make prod-new-site.
# Must match FRAPPE_SITE_NAME_HEADER in platform/dokploy/.env (i.e. your public domain).
PROD_SITE_NAME=nusakura-stg.erp.thinkspedia.id

# The public-facing hostname (used in site_config.json and Traefik routing).
# For dev: dev.localhost  |  For prod: erp.example.com
HOST_NAME=dev.localhost

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=mariadb
DB_PORT=3306
DB_ROOT_PASSWORD=changeme
DB_PASSWORD=frappe

# Uncomment to use PostgreSQL instead of MariaDB
# DB_HOST=postgres
# DB_PORT=5432

# Direct gunicorn port (bypasses Traefik, useful for quick curl / debugging)
HTTP_PUBLISH_PORT=8000

# -----------------------------------------------------------------------------
# Optional dev tools (adminer + mailpit)
# Enabled by default. To disable: set COMPOSE_PROFILES= (empty)
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=tools

# Adminer — MariaDB web UI (http://localhost:ADMINER_PORT)
ADMINER_PORT=8081

# Mailpit — email trap (web UI: http://localhost:MAILPIT_UI_PORT)
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# Traefik reverse-proxy ports
# On Linux without root privileges, change TRAEFIK_HTTP_PORT to 8080 (or any
# port >= 1024) and update your /etc/hosts entry to use that port.
# macOS and WSL2 Docker Desktop: port 80 works without root.
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8082

# -----------------------------------------------------------------------------
# Redis
# Three separate Redis instances for cache, queue, and socketio.
# In dev, all three run as separate containers defined in docker-compose.dev.yml.
# In prod (Nomad), point these to your managed Redis endpoints.
# -----------------------------------------------------------------------------
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
REDIS_SOCKETIO=redis-socketio:6379

# -----------------------------------------------------------------------------
# Gunicorn (web worker)
# Formula for WORKERS: (2 × CPU cores) + 1
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# -----------------------------------------------------------------------------
# GitHub Access (for private app repos at image build time)
# Injected as a BuildKit secret — never baked into the image.
# Set in your shell: export GITHUB_TOKEN=ghp_...
# Then: org-bench build --tag v1.0.0
# DO NOT put the actual token value in this file.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Nomad Deployment
# -----------------------------------------------------------------------------
# Address of the Nomad server (or load-balanced cluster endpoint)
NOMAD_ADDR=http://nomad.example.com:4646
# Nomad ACL token (leave blank if ACL disabled)
NOMAD_TOKEN=

# Deployment scaling — adjust for peak load
NOMAD_WEB_COUNT=2
NOMAD_WORKER_COUNT=2
NOMAD_SCHEDULER_COUNT=1

# Nomad deploy mode: pull (deploy on server) | ship (remote dispatch from CI)
NOMAD_DEPLOY_MODE=pull

# -----------------------------------------------------------------------------
# Dokploy Deployment
# Server: accessible via Netbird VPN at http://100.85.203.161:3000
# Project name must match the Compose project name created in Dokploy UI.
# -----------------------------------------------------------------------------
DOKPLOY_SERVER=http://dokploy.corp.thinkspedia.id:3000
DOKPLOY_TOKEN=
DOKPLOY_PROJECT_NAME=nusakura-erp

# -----------------------------------------------------------------------------
# Traefik / Reverse Proxy (production)
# Single site:   SITES_RULE=Host(`erp.example.com`)
# Multiple sites: SITES_RULE=Host(`a.example.com`) || Host(`b.example.com`)
# -----------------------------------------------------------------------------
SITES_RULE=Host(`dev.localhost`)
LETSENCRYPT_EMAIL=ops@example.com

# -----------------------------------------------------------------------------
# Nginx tuning
# -----------------------------------------------------------------------------
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m
